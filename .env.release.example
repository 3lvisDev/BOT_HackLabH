# HackLabH Release (local only)
NODE_ENV=development

# Dashboard local
PORT=9666
WEB_ADMIN_PASSWORD=<REQUIRED>

# Discord bot release
DISCORD_TOKEN=<REQUIRED>
DISCORD_CLIENT_ID=your-value-here
DISCORD_CLIENT_SECRET=<REQUIRED>
DISCORD_REDIRECT_URI=your-value-here

# Slash commands release
CLIENT_ID=your-value-here
GUILD_ID=your-value-here

# Lavalink local (docker mapped)
LAVALINK_URL=your-value-here
LAVALINK_PASSWORD=<REQUIRED>
LAVALINK_SECURE=false

# Optional
SPOTIFY_CLIENT_ID=CHANGE_ME
SPOTIFY_CLIENT_SECRET=CHANGE_ME
SPOTIFY_MARKET=US
WEB_OWNER_DISCORD_IDS=CHANGE_ME
