{
  "name": "discord-bot-hacklabh",
  "version": "1.1.0",
  "description": "Discord bot for programming community administration.",
  "main": "index.js",
  "engines": {
    "node": ">=18 <=22"
  },
  "scripts": {
    "start": "node index.js",
    "lint": "node scripts/quality/lint-syntax.js",
    "typecheck": "node scripts/quality/typecheck-i18n.js",
    "test": "node tests/run-tests.js",
    "test:integration": "node tests/integration/music-memory.integration.js",
    "build": "node scripts/quality/build-check.js",
    "test:bug": "node tests/bugfix-welcome-goodbye.test.js",
    "test:preservation": "node tests/preservation.test.js",
    "deploy:commands": "node scripts/deploy-commands.js",
    "agent:bootstrap": "powershell -ExecutionPolicy Bypass -File scripts/setup-agent-stack.ps1",
    "emoji:pack": "python3 scripts/download_emoji_pack.py",
    "emoji:fun": "python3 scripts/download_emoji_pack.py --profile fun --out assets/emojis/fun_pack --commands-file assets/emojis/upload_commands_fun.txt --clean-out"
  },
  "dependencies": {
    "@discordjs/opus": "^0.9.0",
    "@discordjs/voice": "^0.16.1",
    "@vvo/tzdb": "^6.198.0",
    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "discord.js": "^14.14.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.18.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "kazagumo": "^3.4.3",
    "libsodium-wrappers": "^0.7.16",
    "opusscript": "^0.0.8",
    "play-dl": "^1.9.7",
    "playwright": "^1.40.0",
    "prism-media": "^1.3.5",
    "shoukaku": "^4.3.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "tweetnacl": "^1.0.3",
    "ws": "^8.16.0",
    "youtube-dl-exec": "^3.0.10",
    "youtube-sr": "^4.3.12",
    "isomorphic-unfetch": "^4.0.2",
    "spotify-url-info": "^3.2.14"
  },
  "devDependencies": {
    "fast-check": "^3.15.0",
    "node-ssh": "^13.2.1"
  }
}
